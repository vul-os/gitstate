# ───────────────────────────────────────────────────────────────────────────
# gitstate — SHARED env for backend (Go) AND frontend (Vite).
# Copy to .env (prod) or .env.dev (dev). Vite reads this file via envDir=root and
# only exposes VITE_* to the browser. Unprefixed vars stay server-side (secret).
# Never commit a real .env — only this .example.
# ───────────────────────────────────────────────────────────────────────────

# ── Core ──
GITSTATE_ENV=dev                       # dev | prod
HTTP_ADDR=:8080
PUBLIC_URL=http://localhost:8080
CONFIG_FILE=config.yaml

# ── Database (Neon Postgres) ──
DATABASE_URL=postgres://user:pass@ep-xxx.region.aws.neon.tech/gitstate?sslmode=require
# Migration reset is refused unless GITSTATE_ENV=dev
DATABASE_MAX_CONNS=10

# ── Auth / JWT ──
JWT_SIGNING_KEY=change-me-32-bytes-min-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h                  # 30d

# ── Calendar (Google/Microsoft) — used for leave/availability sync, NOT login ──
# These power the optional Calendar integration in Settings (push leave / pull busy).
# They are NOT login buttons — sign-in is GitHub/GitLab + email/password.
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_MICROSOFT_TENANT=common

# ── Git platform (GitHub/GitLab) — powers BOTH "Sign in with" AND repo connect ──
# ONE OAuth app per platform, incremental scopes: login requests identity only
# (read:user/user:email | read_user); "Connect repositories" later re-requests the
# repo scopes. The "Sign in with" button appears ONLY when id+secret are set.
# Register the app's Authorization callback URL to cover BOTH callback paths under
# $PUBLIC_URL (set it to "$PUBLIC_URL/" — GitHub matches sub-paths) so both
# /auth/oauth/<platform>/callback (login) and /api/connect/<platform>/callback work.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=

# ── LLM (diff-difficulty sizing, status synthesis) ──
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# ── Billing (EE) — bill in USD, charge in ZAR ──
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
BILLING_CURRENCY_BILL=USD
BILLING_CURRENCY_CHARGE=ZAR
EXCHANGE_PROVIDER=exchangerate-api      # exchangerate-api | openexchangerates
EXCHANGE_API_KEY=
EXCHANGE_TTL=6h

# ── Super admin (bootstrap) ──
SUPER_ADMIN_EMAILS=you@example.com

# ───────────────────────────────────────────────────────────────────────────
# FRONTEND (VITE_*) — safe to ship to the browser. No secrets here.
# ───────────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
VITE_PUBLIC_URL=http://localhost:8080
VITE_PAYSTACK_PUBLIC_KEY=               # public key only (mirror of PAYSTACK_PUBLIC_KEY)
VITE_BILLING_CHARGE_CURRENCY=ZAR

# ── Cloud operator console (super-admin only) ──────────────────────────────
# SUPER_ADMIN_EMAILS=you@example.com   # comma-sep "supreme" admins — immutable, cannot be revoked in-console
# ANALYTICS_SALT=                      # salts the IP hash (raw IPs never stored)
# GEOIP_DB_PATH=/path/GeoLite2-City.mmdb   # optional free MaxMind/db-ip db → country/city in analytics
# FLY_API_TOKEN=    # FLY_ORG_SLUG=    # NEON_API_KEY=   # NEON_PROJECT_ID=   # real COGS reconciliation

# ── Managed-LLM providers (in-process llmux gateway; we cover Anthropic/OpenAI/Google) ──
OPENAI_API_KEY=
GEMINI_API_KEY=
LLM_GATEWAY=llmux          # in-process gateway; managed LLM on-charged at +5%
LLM_MARKUP=1.05
EXCHANGE_PROVIDER=openrate  # in-process ZAR-anchored FX engine (no external key)

# ── Transactional email (invoice delivery) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=billing@gitstate.dev

# ── Email provider: resend | ses | smtp (auto-selected by which is configured) ──
EMAIL_PROVIDER=
RESEND_API_KEY=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Accounting (client-invoice push, OAuth2): Sage / Zoho Books / FreshBooks ──
SAGE_CLIENT_ID=
SAGE_CLIENT_SECRET=
ZOHO_BOOKS_CLIENT_ID=
ZOHO_BOOKS_CLIENT_SECRET=
FRESHBOOKS_CLIENT_ID=
FRESHBOOKS_CLIENT_SECRET=
